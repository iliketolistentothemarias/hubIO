# Copy this file to .env.local and paste your Supabase project values.
# Dashboard: https://supabase.com/dashboard → your project → Settings → API

# Project URL (Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# anon / public key (safe in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# service_role — server-only, never commit to git or expose to clients.
# Required for live messaging to ALL participants (Realtime broadcast from API).
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
